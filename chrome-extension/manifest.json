{
  "manifest_version": 3,
  "name": "ApplyFlow AI - Job Autofiller",
  "version": "1.0.0",
  "description": "Autofill any job application form using your ApplyFlow AI candidate profile.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ApplyFlow AI"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
